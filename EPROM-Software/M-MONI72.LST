  478                   		;*****************************************
  479                   		;* Floppy-Unterprogramme fuer FLO2       *
  480                   		;* verwendet 1797 als Controller         *
  481                   		;* Version 1.0   840506                  *
  482                   		;* Rolf-Dieter Klein (C) 1984 Muenchen   *
  483                   		;*****************************************
  484                   
  485                   		; Die Routinen ermoeglichen sowohl den Anschluss
  486                   		; von Mini-,Mikro- als auch von Maxi-Laufwerken
  487                   		; Die Routinen muessen im RAM stehen 
  488                   		; da auch Buffer am Ende stehen
  489                   		; alle Buffer sind jedoch gesammelt
  490                   
  491         00C0      	flo equ 0c0h 	; Basisadresse Floppy-Controller
  492         00C0      	flo0 equ 0c0h   	; komp.
  493         00C1      	flo1 equ 0c1h
  494         00C2      	flo2 equ 0c2h
  495         00C3      	flo3 equ 0c3h
  496         00C4      	flo4 equ 0c4h 	; Port fuer Zusatzstatus etc.
  497                   
  498                   
  499                   		; FLO4    als Leseport
  500                   		;
  501                   		; 7 6 5 4 3 2 1 0
  502                   		;
  503                   		; DRQ   INTRQ   headld x      x x x x
  504                   		; 0=request
  505                   		;      0=request
  506                   		;  1=head down
  507                   		;
  508                   
  509                   
  510                   		; FLO4    als Schreibport
  511                   		;
  512                   		; 7 6 5 4 3 2 1 0
  513                   		;
  514                   		; sso moton mini dense d c b a
  515                   		;
  516                   		; 1=Seite 1
  517                   		; 0=Motor an
  518                   		;  1=Minilaufwerk
  519                   		;   1=Single Dense
  520                   		;    -------------------------
  521                   		;                                      1=Laufwerk an
  522                   		;
  523                   
