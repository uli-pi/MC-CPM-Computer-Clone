  491                   
  492                   		; Die Routinen ermoeglichen sowohl den Anschluss
  493                   		; von Mini-,Mikro- als auch von Maxi-Laufwerken
  494                   		; Die Routinen muessen im RAM stehen 
  495                   		; da auch Buffer am Ende stehen
  496                   		; alle Buffer sind jedoch gesammelt
  497                   
  498                   		; FLO4    als Leseport
  499                   		;
  500                   		; 7 6 5 4 3 2 1 0
  501                   		;
  502                   		; DRQ   INTRQ   headld x      x x x x
  503                   		; 0=request
  504                   		;      0=request
  505                   		;  1=head down
  506                   		;
  507                   
  508                   
  509                   		; FLO4    als Schreibport
  510                   		;
  511                   		; 7 6 5 4 3 2 1 0
  512                   		;
  513                   		; sso moton mini dense d c b a
  514                   		;
  515                   		; 1=Seite 1
  516                   		; 0=Motor an
  517                   		;  1=Minilaufwerk
  518                   		;   1=Single Dense
  519                   		;    -------------------------
  520                   		;                                      1=Laufwerk an
  521                   		;
  522                   
