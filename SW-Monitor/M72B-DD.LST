 1061 F4F5  FE FF       			cp	0ffh				;non-hex character?
 1062 F4F7  CA F514     			jp	z,hex_to_byte_err	;yes, exit with error
 1063 F4FA  CB 27       			sla	a				;no, move low order nybble to high side
 1064 F4FC  CB 27       			sla	a
