  327                   				; Autobestimmung des Formats
  328 F118              getfl:			; in C ist danach der gueltige
  329                   				; Laufwerkscode, Vorgabe ist
  330                   				; in C die Laufwerksnummer
  331                   				; und ggf. Seite.
  332                   				;
  333 F118  F3          	di  			; ohne Interrupts
  334                   				; testet mini,sd =11
  335                   				;        mini,dd =10
  336                   				;        maxi,sd =01
  337                   				;        maxi,dd =00
  338 F119  3E D0       	ld a,0d0h
  339 F11B  D3 C0       	out (flo0),a 		; Stop Controller
  340 F11D  DB C0       	in a,(flo0) 		; Ints loeschen
  341 F11F  79          	ld a,c
  342 F120  E6 8F       	and 8fh 			; nur Drivecode ok
  343 F122  4F          	ld c,a
  344 F123  CD F285     	call wawa
  345 F126  79          	ld a,c
  346 F127  F6 30       	or 00110000b		;mini sd vorgeben		
  347 F129  4F          	ld c,a
  348 F12A  CD F148     	call get1fl
