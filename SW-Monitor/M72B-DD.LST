  291 F0E7  24          	INC H
  292 F0E8  7C          	LD A,H
  293 F0E9  FE F0       	CP 0F0H  		;ALL RAM
  294 F0EB  28 08       	JR Z,LXM2 		;READY 0F000H
  295 F0ED  7E          	LD A,(HL) 		;max 0f000h, da dort Monitor startet
  296 F0EE  2F          	CPL
  297 F0EF  77          	LD (HL),A
  298 F0F0  BE          	CP (HL)
  299 F0F1  2F          	CPL
  300 F0F2  77          	LD (HL),A
  301 F0F3  28 F2       	JR Z,LXM1
  302 F0F5              LXM2:
  303 F0F5  25          	DEC H
  304 F0F6  01 FFDD     	LD BC,EXIT-ENDX
  305 F0F9  09          	ADD HL,BC
  306 F0FA  C1          	POP BC
  307 F0FB  C9          	RET
