 1126 F579  2A D300     			ld	hl,(current_location)	;check if at end of decimal string
 1127 F57C  37          			scf					;get ready to subtract de from buffer addr.
 1128 F57D  3F          			ccf					;set carry to zero (clear)
 1129 F57E  ED 42       			sbc	hl,bc				;keep going if bc > or = hl (buffer address)
 1130 F580  DA F58C     			jp	c,decimal_continue	;borrow means bc > hl
 1131 F583  CA F58C     			jp	z,decimal_continue	;z means bc = hl
