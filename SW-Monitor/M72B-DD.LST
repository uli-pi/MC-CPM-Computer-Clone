  233                   
  234 F0B1              CSTS:		
  235 F0B1  3A F10E     	LD A,(IOBYT)
  236 F0B4  E6 03       	AND 3
  237 F0B6  20 09       	JR NZ,CS0
  238 F0B8              TTYCSTS:
  239 F0B8  DB F1       	IN A,(SIOASTS)
  240 F0BA  E6 01       	AND 1
  241 F0BC  C8          	RET Z
  242 F0BD  3E FF       	LD A,0FFH
  243 F0BF  B7          	OR A
  244 F0C0  C9          	RET
  245                   		;
  246 F0C1              CS0:
  247 F0C1  C3 F10B     	JP USERCSTS 		;USER BEREICH
  248                   
  249                   ; Das IOBYTE dient der Umschaltung von
  250                   ; physikalischem nach logischem Geraet
  251                   ; Es hat die gleiche Bedeutung
  252                   ; wie im CP/M-Bios 
  253                   ;
  254 F0C4              IOBYTE:
  255 F0C4  3A F10E     	LD A,(IOBYT)
  256 F0C7  C9          	RET
  257                   ; IOSET
  258                   ; kann z.B. im Bios gesetzt werden
  259 F0C8              IOSET:
  260 F0C8  79          	LD A,C
  261 F0C9  32 F10E     	LD (IOBYT),A
  262 F0CC  C9          	RET
  263                   ;
  264 F0CD              MEMCK:	;prueft den Speicherbereich und gibt
  265                   		;die hoechste verfuegbare Zelle an
  266                   ;
  267 F0CD  E5          	PUSH HL
  268 F0CE  CD F0DA     	CALL MEMSIZ
  269 F0D1  7D          	LD A,L
  270 F0D2  D6 3C       	SUB 3CH
  271 F0D4  30 01       	JR NC,LXBZ
  272 F0D6  25          	DEC H
  273 F0D7              LXBZ:
  274 F0D7  44          	LD B,H
  275 F0D8  E1          	POP HL
  276 F0D9  C9          	RET
  277                   
  278 F0DA              MEMSIZ:	; --- Unterprogramm fuer Speicherendebestimmung ---
  279 F0DA  C5          	PUSH BC
  280 F0DB  21 FFFF     	LD HL,-1
  281 F0DE              LXM0:
  282 F0DE  24          	INC H
  283 F0DF  7E          	LD A,(HL)
  284 F0E0  2F          	CPL
  285 F0E1  77          	LD (HL),A
  286 F0E2  BE          	CP (HL)
  287 F0E3  2F          	CPL
  288 F0E4  77          	LD (HL),A
  289 F0E5  20 F7       	JR NZ,LXM0
  290 F0E7              LXM1:
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   6
