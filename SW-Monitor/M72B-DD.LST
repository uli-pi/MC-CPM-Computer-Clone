  998                   ;
  999                   ;Creates a two-char hex string from the byte value passed in register A
 1000                   ;Location to place string passed in HL
 1001                   ;String is zero-terminated, stored in 3 locations starting at HL
 1002                   ;Also uses registers b,d, and e
 1003                   ;
 1004 F4B0  47          byte_to_hex_string:	ld	b,a		;store original byte
 1005 F4B1  CB 3F       			srl	a			;shift right 4 times, putting
 1006 F4B3  CB 3F       			srl	a			;high nybble in low-nybble spot
 1007 F4B5  CB 3F       			srl	a			;and zeros in high-nybble spot
 1008 F4B7  CB 3F       			srl	a
 1009 F4B9  16 00       			ld	d,000h		;prepare for 16-bit addition
 1010 F4BB  5F          			ld	e,a			;de contains offset
 1011 F4BC  E5          			push	hl			;temporarily store string target address
 1012 F4BD  21 F516     			ld	hl,hex_char_table	;use char table to get high-nybble character
 1013 F4C0  19          			add	hl,de			;add offset to start of table
 1014 F4C1  7E          			ld	a,(hl)		;get char
 1015 F4C2  E1          			pop	hl			;get string target address
 1016 F4C3  77          			ld	(hl),a		;store first char of string
 1017 F4C4  23          			inc	hl			;point to next string target address
 1018 F4C5  78          			ld	a,b			;get original byte back from reg b
 1019 F4C6  E6 0F       			and	00fh			;mask off high-nybble
 1020 F4C8  5F          			ld	e,a			;d still has 000h, now de has offset
 1021 F4C9  E5          			push	hl			;temp store string target address
 1022 F4CA  21 F516     			ld	hl,hex_char_table	;start of table
 1023 F4CD  19          			add	hl,de			;add offset
 1024 F4CE  7E          			ld	a,(hl)		;get char
 1025 F4CF  E1          			pop	hl			;get string target address
 1026 F4D0  77          			ld	(hl),a		;store second char of string
 1027 F4D1  23          			inc	hl			;point to third location
 1028 F4D2  3E 00       			ld	a,000h		;zero to terminate string
 1029 F4D4  77          			ld	(hl),a		;store the zero
 1030 F4D5  C9          			ret				;done
 1031                   ;
 1032                   ;Converts a single ASCII hex char to a nybble value
 1033                   ;Pass char in reg A. Letter numerals must be upper case.
 1034                   ;Return nybble value in low-order reg A with zeros in high-order nybble if no error.
 1035                   ;Return 0ffh in reg A if error (char not a valid hex numeral).
 1036                   ;Also uses b, c, and hl registers.
 1037 F4D6  21 F516     hex_char_to_nybble:	ld	hl,hex_char_table
 1038 F4D9  06 0F       			ld	b,00fh			;no. of valid characters in table - 1.
 1039 F4DB  0E 00       			ld	c,000h			;will be nybble value
 1040 F4DD  BE          hex_to_nybble_loop:	cp	(hl)			;character match here?
 1041 F4DE  CA F4EA     			jp	z,hex_to_nybble_ok	;match found, exit
 1042 F4E1  05          			dec	b				;no match, check if at end of table
 1043 F4E2  FA F4EC     			jp	m,hex_to_nybble_err	;table limit exceded, exit with error
 1044 F4E5  0C          			inc	c				;still inside table, continue search
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page  19
