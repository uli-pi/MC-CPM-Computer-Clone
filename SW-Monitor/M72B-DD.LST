  349 F12D  D0          	ret nc  			; kein Fehler, no carry
  350 F12E  79          	ld a,c
  351 F12F  E6 AF       	and 10101111b
  352 F131  4F          	ld c,a
  353 F132  CD F148     	call get1fl
  354 F135  D0          	ret nc
  355 F136  79          	ld a,c
  356 F137  E6 8F       	and 10001111b
  357 F139  F6 10       	or  00010000b
  358 F13B  4F          	ld c,a
  359 F13C  CD F148     	call get1fl
  360 F13F  D0          	ret nc
  361 F140  79          	ld a,c
  362 F141  E6 8F       	and 10001111b
  363 F143  4F          	ld c,a
  364 F144  CD F148     	call get1fl
  365 F147  C9          	ret  				; carry, dann Fehler
  366                   
  367                   
  368 F148              get1fl:
  369 F148  3A F43B     	ld a,(floc0)
  370                   				;1 	if a=1  		;FLO1 
  371 F14B  FE 01       	CP 1  
  372 F14D  C2 F156     	JP NZ,.L1
  373 F150  79          	ld a,c
  374 F151  EE 10       	xor 10h 			;wenn Flo1 dann invertieren Dichtebit
  375                   				;1 	else  	;FLO2
  376 F153  C3 F157     	JP .L2
  377 F156              .L1:
  378 F156  79          	ld a,c
  379                   				;1 	endif    
  380 F157              .L2:
  381                   
  382 F157  D3 C4       	out (flo4),a 		; Drive-Code probieren
  383 F159  3E 0F       	ld a,0fh 			; RSTORE-Befehl mit Verify verwenden
  384 F15B  D3 C0       	out (flo0),a 		; und ausgeben
  385 F15D              get2fl:
  386 F15D  DB C4       	in a,(flo4)
  387 F15F  E6 40       	and 40h 			; Bit 6 pruefen
  388 F161  28 FA       	jr z,get2fl 		; bis INT da.
  389 F163  DB C0       	in a,(flo0) 		; und dann status lesen, int loeschen
  390 F165  E6 98       	and  10011000b 		; krit. Bit testen 
  391 F167  37          	scf  				; falls Fehler, dann setzen
  392 F168  C0          	ret nz  			; carry=Fehler
  393 F169  AF          	xor a
  394 F16A  C9          	ret  				; sonst ok nocarry (c=Code)
