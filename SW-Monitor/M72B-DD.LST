Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   1
M72A-DD Z80

    1                   ;---------------------------------------------------------------
    2                   ;Monitor fuer MC-Computer Platine SYS-1
    3                   ;Assembliert mit Z80ASM von SLR Systems wegen der langen
    4                   ;Label die mit einigen anderen Assemblern nicht moeglich sind.
    5                   ;
    6                   ;Erstellt 04/2026 von U. Haumann
    7                   ;Enthaelt Floppy Routinen aus RDK Monitor 1.1, sowie Teile aus 
    8                   ;dem Monitor von Donn Stewart fuer den "CPU-Ville" Z80 Computer.
    9                   ;Single Density boot wird uebersprungen, kann aber einfach
   10                   ;auskommentiet oder gelvscht werden wenn original gewuenscht.
   11                   ;Flo1 und Flo2 waehlber auf Hardware Basis Adresse 0C0h.
   12                   ;Der Mointor erwartet 64KB Ram Memory. Er darf selbst nicht
   13                   ;groesser als 4KB werden, es sein denn man schiebt die MON_ADR
   14                   ;und CCP weiter nach unten. Der CPM Bereich verkleinert sich dann.
   15                   ;Der Monitor kopiert sich nach Reset an das Speicherende
   16                   ;auf den Wert in MON_ADR und gibt den unteren RAM Bereich frei.
   17                   ;Dies wird auf der SYS1 mit einem Lesebefehl auf
   18                   ;Adresse 7000h erreicht. Das Eprom ist dann ausgeblendet.
   19                   ;Somit steht der Speicher durchgaengig ab 0000h bis zu MON_ADR
   20                   ;zur Verfuehgung.
   21                   ;Das CPM BIOS fuer den MC-Computer ueberschreibt den Monitorbereich
   22                   ;ab FC00h. Alle relevanten Teile f|r den Betrieb des Rechners 
   23                   ;muessen vor FC00h plaziert werden.
   24                   ;
   25                   ;---------------------------------------------------------------
   26                   			.Z80
   27                   
   28         0000      			ORG	0000h		;Beginn iM ROM AUF ADRESSE 0
   29                   ;
   30         F000      		Mon_ADR	EQU 0F000H	;Monitor Zieladresse
   31         D400      		CCP		EQU 0D400H	;CP/M CCP Anfang
   32                   ;
   33                   ;Routine um den ROM Inhalt nach "Mon_ADR" zu schieben
   34                   ;
   35 0000              BEGINN:
   36 0000  31 FFFF     	LD SP,0FFFFH 		;DUMMY-LOAD 
   37 0003  3E C9       	LD A,0C9H 			;ABLAGE RET-BEFEHL
   38 0005  32 F000     	LD (Mon_ADR),A 		;AUF ZIELADRESSE
   39 0008  CD F000     	CALL Mon_ADR 		;FESTSTELLEN
   40 000B              ANF:					;DER EIGENEN ADRESSE,
   41 000B  3B          	DEC SP  			;UM START VON BELIEBIGER
   42 000C  3B          	DEC SP  			;STELLE AUS ZU ERMOEGLICHEN
   43 000D  D1          	POP DE  			;FUER TESTS SEHR GUT
   44 000E  21 0012     	LD HL,HAUPTP-ANF
   45 0011  19          	ADD HL,DE
   46 0012  11 F000     	LD DE,Mon_ADR 		;TRANSPORT ALLER ZELLEN
   47 0015  01 0FFF     	LD BC,0FFFH 		;4K TRANSFER
   48 0018  ED B0       	LDIR  			
   49 001A  C3 F000     	JP Mon_ADR 		;und los gehts
   50 001D              HAUPTP:				;DISTANZ-MERKER
   51                   ;
   52                   		.PHASE Mon_ADR 	;Monitor auf Zieladresse einstellen
   53                   ;
   54                   ; --- START DES EIGENTLICHEN MONITORS ---
   55                   ;
   56         000D      	CR 		EQU 0DH
   57         000A      	LF 		EQU 0AH
   58         0007      	BELL		EQU 07H
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   2
M72A-DD Z80

   59         00FF      	RUB 		EQU 0FFH
   60         001B      	ESC		EQU 1BH
   61                   ;
   62         0038      	RST7		EQU 38H	; ANFANG VERSCHIEBBAR
   63                   					; der Vektor RST7 wird fuer Breakpoints gebraucht
   64                   ;
   65                   ;Adressen des Seriell Port MC Computer SIO/PIO Karte
   66                   ;
   67         00F0      	SIOADAT	EQU 0F0H
   68         00F1      	SIOASTS	EQU 0F1H
   69         00F2      	SIOBDAT	EQU 0F2H
   70         00F3      	SIOBSTS	EQU 0F3H
   71         0001      	RXRDY		EQU 001h			;RX Ready Bit
   72         0004      	TXRDY		EQU 004h			;TX Ready Bit
   73                   ;
   74                   ;Adressen IDE Port CF-80 Karte
   75                   ;
   76         0018      	IDEDATA	EQU 018h			;IDE Daten Register
   77         001A      	SECCND	EQU 01ah			;Sector Count Register
   78         001B      	LBA7		EQU 01bh			;LBA Bits 0-7
   79         001C      	LBA15		EQU 01ch			;LBA Bits 8-15
   80         001D      	LBA23		EQU 01dh			;LBA Bits 16-23
   81         001E      	IDEHEAD	EQU 01eh			;IDE Drive Head Register
   82         001F      	IDESTAT	EQU 01fh			;IDE Command/Status Register
   83                   ;
   84                   ; Basisadresse Floppy-Controller FLO2
   85                   ;
   86         00C0      	flo 		equ 0c0h 		
   87         00C0      	flo0 		equ 0c0h   	
   88         00C1      	flo1 		equ 0c1h
   89         00C2      	flo2		equ 0c2h
   90         00C3      	flo3		equ 0c3h
   91         00C4      	flo4		equ 0c4h 			; Port fuer Zusatzstatus etc.
   92                   
   93                   ;
   94                   ;Die Unterprogramme der seriellen Ein/Ausgabe brauchen Speicher im RAM
   95                   ;
   96         D300      		Ser_ADR	equ	CCP-0100H		;Basis Adresse Seriell Puffer
   97                   								;liegt direkt unterhalb CCP
   98         D300      current_location	equ	Ser_ADR+00H	;word variable in RAM
   99         D302      line_count			equ	Ser_ADR+02H	;byte variable in RAM
  100         D303      byte_count			equ	Ser_ADR+03H	;byte variable in RAM
  101         D304      value_pointer		equ	Ser_ADR+04H	;word variable in RAM
  102         D306      current_value		equ	Ser_ADR+06H	;word variable in RAM
  103         D308      buffer			equ	Ser_ADR+08H	;buffer up to CCP
  104                   ;
  105                   ;* VEKTOR TABELLE *
  106                   ; CSTS 0FFH IN A, FALLS ZEICHEN DA
  107                   ; IOCHK IN A AKTUELLE IO-KONFIGURATION
  108                   ; IOSET VERAENDERN, IO IN C-REG
  109                   ; MEMCK IN B HIGH IN A LOW MEMORY
  110                   ; TRAP/BREAKPOINT ENTRY
  111                   ;
  112                   ; --- Sprungtabellen am ROM Start
  113                   ;feste Einsprungadressen fuer andere Programme
  114                   ;
  115 F000  C3 F042     	JP BEGIN			;Kaltstart Monitor
  116 F003  C3 F045     	JP CI				;Consol Input Routine
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   3
M72A-DD Z80

  117 F006  C3 F06D     	JP RI
  118 F009  C3 F059     	JP CO				;Consol Output Routine
  119 F00C  C3 F083     	JP POO
  120 F00F  C3 F09A     	JP LO
  121 F012  C3 F0B1     	JP CSTS
  122 F015  C3 F0C4     	JP IOBYTE
  123 F018  C3 F0C8     	JP IOSET
  124 F01B  C3 F0CD     	JP MEMCK
  125 F01E              TRAP:	
  126 F01E  C3 F03F     	JP RESTA1			;Restart Vector
  127 F021  C3 F1D5     	JP FLOP  	 		;neue Floppy-Schnittstelle rev 1.0
  128 F024  C3 F16B     	JP MAXI  			;FLOPPY EXEC VEKTOR SOFT (alt)
  129 F027  C3 F1A6     	JP MINI  			;FLOPPY EXEC VEKTOR MINI (alt)	
  130 F02A  C3 F6B2     	JP IDE_read		;IDE Sektor lesen
  131 F02D  C3 F6F1     	JP IDE_write		;IDE Sektor schreiben
  132 F030  C3 F84A     	JP mon_cold_start	;Monitor Kalt Start, Hardware init
  133 F033  C3 F883     	JP mon_warm_start	;Monitor Warm Start
  134 F036  C3 F440     	JP write_string		;gibt mit 0 terminierten String aus
  135                   ;
  136 F039  F0FC        	DEFW TABSTART 		;TABELLEN-START, USER-BEREICH
  137                   					;SPRUNGTABELLE, IMMER
  138                   					;INDIREKT VERWENDEN
  139 F03B  FF45        	DEFW LASTMON 		;ADRESSE LETZTE BELEGTE ZELLE
  140                   					;DES MONITORS DANACH PATCH FREI
  141 F03D  F730        	DEFW FREEMEM 		;Lade-Adresse hinter IO-Gebiet
  142                   
  143 F03F              RESTA1:
  144 F03F  C3 FAC9     	JP RESTA 			;kann kurzgeschlossen werden
  145                   					;nach freemem Ueberschreibung
  146                   ;
  147 F042              BEGIN:
  148 F042  C3 F826     	JP BEGIN1 			;kurzschliessen ggf.
  149                   					;ende fixed gebiet
  150                   ;
  151                   ;**************************************
  152                   ;* IO Routinen
  153                   ;**************************************
  154                   ;
  155                   ; --- Consol Input ROUTINE ---
  156 F045              CI:
  157 F045  3A F10E     	LD A,(IOBYT)		;Abfrage des IO Byte
  158 F048  E6 03       	AND 3 			;CONSOLMASKE
  159 F04A  20 0A       	JR NZ,CI1 			;Wenn nicht Standart Console
  160                   ;
  161 F04C              TTYIN:
  162 F04C  DB F1       	in 	a,(SIOASTS)		;get status
  163 F04E  E6 01       	and 	RXRDY				;check RxRDY bit
  164 F050  CA F04C     	jp 	z,TTYIN			;not ready, loop
  165 F053  DB F0       	in 	a,(SIOADAT)		;get char
  166 F055  C9          	ret
  167                   ;
  168 F056              CI1:
  169 F056  C3 F0FC     	JP USERCI  		;Dort Sprung zur moeglicher Benutzer
  170                   					;Console
  171                   ;
  172                   ; --- Consol Output ROUTINE --- 
  173 F059              CO:
  174 F059  3A F10E     	LD A,(IOBYT)		;Abfrage des IO Byte
Z80ASM SuperFast Relocating Macro Assembler     	    Z80ASM 1.32 Page   4
M72A-DD Z80

  175 F05C  E6 03       	AND 3	
  176 F05E  20 0A       	JR NZ,CO1			;Wenn nicht Standard Console
  177                   ;					
  178 F060              TTYOUT:				;bei Aufruf mus auszugebendes Zeichen
  179                   					;in Register C sein
  180 F060  DB F1       	IN A,(SIOASTS)
  181 F062  E6 04       	and	TXRDY				;check TxRDY bit
  182 F064  28 FA       	JR Z,TTYOUT
  183 F066  79          	LD A,C			
  184 F067  D3 F0       	OUT (SIOADAT),A
  185 F069  C9          	RET
  186 F06A              CO1:
  187 F06A  C3 F102     	JP USERCO 			;DORT SPRUNG MOEGLICH
  188                   ;
  189                   ; --- RI ROUTINE ---
  190 F06D              RI:
  191 F06D  3A F10E     	LD A,(IOBYT)
  192 F070  E6 0C       	AND 00001100B
  193 F072  CA F045     	JP Z,CI  			;AR=T
  194 F075  FE 04       	CP 00000100B 
  195 F077  C2 F0FF     	JP NZ,USERRI
  196 F07A              LXLPI:				;AR=P
  197 F07A  DB F3       	IN A,(SIOBSTS)
  198 F07C  E6 01       	AND 1
  199 F07E  28 FA       	JR Z,LXLPI
  200 F080  DB F2       	IN A,(SIOBDAT)
  201 F082  C9          	RET
  202                   ;
  203 F083              POO:		; --- MAIN POO ROUTINE ---
  204                   		;HIER ABFRAGE IOBYT MOEGLICH
  205                   
  206 F083  3A F10E     	LD A,(IOBYT)
  207 F086  E6 30       	AND 00110000B
  208 F088  CA F059     	JP Z,CO  			;AP=T
  209 F08B  FE 10       	CP 00010000B
  210 F08D  C2 F105     	JP NZ,USERPOO
  211 F090              LXLPO:				;AP=P
  212 F090  DB F3       	IN A,(SIOBSTS)
  213 F092  E6 04       	AND 4
  214 F094  28 FA       	JR Z,LXLPO
  215 F096  79          	LD A,C
  216 F097  D3 F2       	OUT (SIOBDAT),A
  217 F099  C9          	RET
  218                   ;
  219 F09A              LO:
  220 F09A  3A F10E     	LD A,(IOBYT)
  221 F09D  E6 C0       	AND 0C0H
  222 F09F  CA F060     	JP Z,TTYOUT 		;AL=T
  223 F0A2  FE 80       	CP 10000000B 		
  224 F0A4  C2 F108     	JP NZ,USERLO
  225                   					;AL=L
  226 F0A7              LO1:
  227 F0A7  DB F3       	IN A,(SIOBSTS)
  228 F0A9  E6 04       	AND 4
  229 F0AB  28 FA       	JR Z,LO1
  230 F0AD  79          	LD A,C
  231 F0AE  D3 F2       	OUT (SIOBDAT),A
  232 F0B0  C9          	RET
