  407                   					; angesprochen, bei Mini mit Seitenpruefung auf 1.
  408                   					; nur fuer SD
  409                   
  410 F16B              maxi:					; c=0,1,2,3
  411                   					; 0,2 gekoppelt  1,3 gekoppelt
  412 F16B  CD F171     	call setcod
  413 F16E  C3 F1D5     	jp flop 			; sso-flag auf 0 setzen, jedoch stepflag
  414                   					; gueltig wenn bit 7 gesetzt.
  415                   
  416 F171              setcod:
  417 F171  79          	ld a,c  			; SD MAXI
  418 F172  E6 03       	and 3  			; muss Bereich 0..3 sein
  419 F174  FE 00       	cp 0  			; 0 seite 0
  420 F176  20 03       	jr nz,max1
  421 F178  0E 11       	ld c,00010001b 		; LW 1
  422 F17A  C9          	ret
  423 F17B              max1:
  424 F17B  FE 01       	cp 1
  425 F17D  20 03       	jr nz,max2
  426 F17F  0E 12       	ld c,00010010b 		; LW 2 seite 0
  427 F181  C9          	ret
  428 F182              max2:
  429 F182  FE 02       	cp 2
  430 F184  20 03       	jr nz,max3
  431 F186  0E 91       	ld c,10010001b 		; LW 1 seite 1
  432 F188  C9          	ret
  433 F189              max3:
  434 F189  0E 92       	ld c,10010010b 		; LW 2 seite 1
  435 F18B  C9          	ret
  436                   
  437                   
  438 F18C              set2cod:
  439 F18C  E6 03       	and 3  			;0,1,2,3 erlaubt
  440 F18E  FE 00       	cp 0
