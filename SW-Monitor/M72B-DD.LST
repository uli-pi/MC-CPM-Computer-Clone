 1048 F4EB  C9          			ret
 1049 F4EC  3E FF       hex_to_nybble_err:	ld	a,0ffh		;error value
 1050 F4EE  C9          			ret
 1051                   ;
 1052                   ;Converts a hex character pair to a byte value
 1053                   ;Called with location of high-order char in HL
 1054                   ;If no error carry flag clear, returns with byte value in register A, and
 1055                   ;HL pointing to next mem location after char pair.
 1056                   ;If error (non-hex char) carry flag set, HL pointing to invalid char
 1057 F4EF  7E          hex_to_byte:		ld	a,(hl)		;location of character pair
 1058 F4F0  E5          			push	hl				;store hl (hex_char_to_nybble uses it)
 1059 F4F1  CD F4D6     			call	hex_char_to_nybble
