  959                   ;
  960                   ;Subroutine to get a string from serial input, place in buffer.
  961                   ;Buffer address passed in HL reg.
  962                   ;Uses A,BC,DE,HL registers (including calls to other subroutines).
  963                   ;Line entry ends by hitting return key. Return char not included in string (replaced by zero).
  964                   ;Backspace editing OK. No error checking.
  965                   ;
  966 F474  0E 00       get_line:		ld	c,000h		;line position
  967 F476  7C          			ld	a,h			;put original buffer address in de
  968 F477  57          			ld	d,a			;after this don't need to preserve hl
  969 F478  7D          			ld	a,l			;subroutines called don't use de
  970 F479  5F          			ld	e,a
  971 F47A  DB F1       get_line_next_char:	in 	a,(SIOASTS)		;get status
  972 F47C  E6 01       			and 	RXRDY			;check RxRDY bit
  973 F47E  CA F47A     			jp 	z,get_line_next_char	;not ready, loop
  974 F481  DB F0       			in 	a,(SIOADAT)	;get char
  975 F483  FE 0D       			cp	00dh			;check if return
  976 F485  C8          			ret	z			;yes, normal exit
  977 F486  FE 7F       			cp	07fh			;check if backspace (VT102 keys)
  978 F488  CA F49C     			jp	z,get_line_backspace	;yes, jump to backspace routine
  979 F48B  FE 08       			cp	008h			;check if backspace (ANSI keys)
  980 F48D  CA F49C     			jp	z,get_line_backspace	;yes, jump to backspace
  981 F490  CD F43C     			call	write_char		;put char on screen
  982 F493  12          			ld	(de),a		;store char in buffer
  983 F494  13          			inc	de			;point to next space in buffer
  984 F495  0C          			inc	c			;inc counter
  985 F496  3E 00       			ld	a,000h
  986 F498  12          			ld	(de),a		;leaves a zero-terminated string in buffer
