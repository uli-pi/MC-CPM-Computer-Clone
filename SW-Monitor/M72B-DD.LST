 1451 F89E  01 FD65     parse:		ld	bc,parse_table		;bc is pointer to parse_table
 1452 F8A1  0A          parse_start:	ld	a,(bc)			;get pointer to match string from parse table
 1453 F8A2  5F          			ld	e,a
 1454 F8A3  03          			inc	bc
 1455 F8A4  0A          			ld	a,(bc)			
 1456 F8A5  57          			ld	d,a				;de will is pointer to strings for matching
 1457 F8A6  1A          			ld	a,(de)			;get first char from match string
 1458 F8A7  F6 00       			or	000h				;zero?
 1459 F8A9  CA F8C4     			jp	z,parser_exit		;yes, exit no_match
 1460 F8AC  21 D308     			ld	hl,buffer			;no, parse input string 
 1461 F8AF  BE          match_loop:	cp	(hl)				;compare buffer char with match string char
 1462 F8B0  C2 F8BE     			jp	nz,no_match		;no match, go to next match string
 1463 F8B3  F6 00       			or	000h				;end of strings (zero)?
 1464 F8B5  CA F8C4     			jp	z,parser_exit		;yes, matching string found
