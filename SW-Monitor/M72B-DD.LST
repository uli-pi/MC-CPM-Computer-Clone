 1113                   ;
 1114                   ;Subroutine to convert a decimal string to a word value
 1115                   ;Call with address of string in HL, pointer to end of string in DE
 1116                   ;Carry flag set if error (non-decimal char)
 1117                   ;Carry flag clear, word value in HL if no error.
 1118 F567  42          decimal_string_to_word:	ld	b,d
 1119 F568  4B          			ld	c,e				;use BC as string pointer
 1120 F569  22 D300     			ld	(current_location),hl	;store addr. of start of buffer in RAM word variable
 1121 F56C  21 0000     			ld	hl,000h			;starting value zero
 1122 F56F  22 D306     			ld	(current_value),hl
